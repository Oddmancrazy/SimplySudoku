    <string name="about_app">About SimplySudoku</string>
    <string name="about_modes_title">Game Modes</string>
    <string name="classic">Classic</string>
    <string name="classic_desc">For the traditional player. Minimal help, no error markings along the way – just like pen and paper.</string>
    <string name="modern">Modern</string>
    <string name="modern_desc">Provides visual support by highlighting duplicates and errors immediately. Perfect for a faster and more guided experience.</string>
    <string name="about_features_title">Features</string>
    <string name="feature_pause_title">Fair-Play Pause</string>
    <string name="feature_pause_desc">When you pause the game, the board is covered. This ensures the clock stops fairly, so you can\'t plan your next move while time is standing still.</string>
    <string name="feature_layout_title">Flexible Layout</string>
    <string name="feature_layout_desc">Playing on a large screen or left-handed? In landscape mode, you can easily swap sides of the control panel for the best ergonomics.</string>
    <string name="feature_history_title">Stats &amp; Backup</string>
    <string name="feature_history_desc">The app tracks your best times. See quick highlights on the front page or dive into your full history. Your data is yours – you can back it up, delete it, or move it to a new device.</string>
    <string name="about_story_title">The Story Behind</string>
    <string name="about_story_desc">SimplySudoku was developed by someone who just wanted a clean and beautiful app where you could start playing with a single tap, without clutter or unnecessary menus.</string>

    <string name="goal">Goal</string>
    <string name="goal_desc">Fill the entire board so that each row, column, and 3×3 box contains the numbers 1 to 9 once each.</string>
