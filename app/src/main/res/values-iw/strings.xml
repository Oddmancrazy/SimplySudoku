    <string name="classic">קלאסי</string>
    <string name="classic_desc">עבור השחקן המסורתי. עזרה מינימלית, ללא סימון שגיאות במהלך המשחק – בדיוק כמו דף ועט.</string>
    <string name="modern">מודרני</string>
    <string name="modern_desc">מספק עזרה חזותית על ידי סימון כפילויות ושגיאות באופן מיידי. מושלם לחוויה מהירה ומודרכת יותר.</string>
    <string name="about_features_title">תכונות</string>
    <string name="feature_pause_title">השהיית משחק הוגן</string>
    <string name="feature_pause_desc">כשאתה משהה את המשחק, הלוח מכוסה. זה מבטיח שהשעון עוצר בצורה הוגנת, כך שלא תוכל לתכנן את המהלך הבא שלך בזמן שהזמן עומד מלכת.</string>
    <string name="feature_layout_title">פריסה גמישה</string>
    <string name="feature_layout_desc">משחק על מסך גדול או שמאלי? במצב לרוחב, תוכל להחליף בקלות בין צידי לוח הבקרה לארגונומיה מיטבית.</string>
    <string name="feature_history_title">סטטיסטיקה וגיבוי</string>
    <string name="feature_history_desc">האפליקציה עוקבת אחר הזמנים הטובים ביותר שלך. ראה שיאים בדף הבית או צלול להיסטוריה המלאה שלך. הנתונים שלך הם שלך – תוכל לגבות אותם, למחוק אותם או להעביר אותם למכשיר חדש.</string>
    <string name="about_story_title">הסיפור מאחורי</string>
    <string name="about_story_desc">SimplySudoku פותחה על ידי מישהו שפשוט רצה אפליקציה נקייה ויפה שבה אפשר להתחיל לשחק בלחיצה אחת, ללא עומס או תפריטים מיותרים.</string>

