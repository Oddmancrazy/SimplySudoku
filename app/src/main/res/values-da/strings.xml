    <string name="about_modes_title">Spiltilstande</string>
    <string name="classic">Klassisk</string>
    <string name="classic_desc">Til den traditionelle spiller. Minimal hjælp, ingen fejlmarkeringer undervejs – ligesom pen og papir.</string>
    <string name="modern">Moderne</string>
    <string name="modern_desc">Giver visuel støtte ved at markere dubletter og fejl med det samme. Perfekt til en hurtigere og mere guidet oplevelse.</string>
    <string name="about_features_title">Funktioner</string>
    <string name="feature_pause_title">Fair-Play Pause</string>
    <string name="feature_pause_desc">Når du pauser spillet, dækkes pladen. Dette sikrer, at uret stopper retfærdigt, så du ikke kan planlægge dit næste træk, mens tiden står stille.</string>
    <string name="feature_layout_title">Fleksibelt layout</string>
    <string name="feature_layout_desc">Spiller du på en stor skærm eller er du venstrehåndet? I liggende tilstand kan du nemt skifte side på kontrolpanelet for den bedste ergonomi.</string>
    <string name="feature_history_title">Statistik &amp; Backup</string>
    <string name="feature_history_desc">Appen holder styr på dine bedste tider. Se hurtige højdepunkter på forsiden eller dyk ned i din fulde historik. Dine data er dine – du kan tage backup, slette dem eller flytte dem til en ny enhed.</string>
    <string name="about_story_title">Historien bag</string>
    <string name="about_story_desc">SimplySudoku blev udviklet af en, der bare ønskede en ren og smuk app, hvor man kunne begynde at spille med et enkelt tryk, uden rod eller unødvendige menuer.</string>

    <string name="goal">Mål</string>
    <string name="goal_desc">Udfyld hele pladen, så hver række, kolonne og 3×3 boks indeholder tallene 1 til 9 præcis én gang.</string>
