    <string name="classic">Klassisk</string>
    <string name="classic_desc">For den tradisjonelle spilleren. Minimal hjelp, ingen feilmarkeringer underveis – akkurat som penn og papir.</string>
    <string name="modern">Moderne</string>
    <string name="modern_desc">Gir visuell støtte ved å markere duplikater og feil umiddelbart. Perfekt for en raskere og mer guidet opplevelse.</string>
    <string name="about_features_title">Funksjoner</string>
    <string name="feature_pause_title">Fair-Play Pause</string>
    <string name="feature_pause_desc">Når du pauser spillet, dekkes brettet til. Dette sikrer at klokken stopper rettferdig, slik at du ikke kan planlegge neste trekk mens tiden står stille.</string>
    <string name="feature_layout_title">Fleksibelt oppsett</string>
    <string name="feature_layout_desc">Spiller du på stor skjerm eller er du venstrehendt? I liggende modus kan du enkelt bytte side på kontrollpanelet for best mulig ergonomi.</string>
    <string name="feature_history_title">Statistikk og backup</string>
    <string name="feature_history_desc">Appen holder kontroll på dine beste tider. Se raske høydepunkter på forsiden eller dykk ned i full historikk. Dine data er dine – du kan ta backup, slette alt, eller flytte dem til en ny enhet.</string>
    <string name="about_story_title">Historien bak</string>
    <string name="about_story_desc">SimplySudoku ble utviklet av en som bare ønsket seg en ren og pen app der man kunne sette i gang og spille med ett enkelt trykk, uten rot eller unødvendige menyer.</string>

    <string name="goal">Målet</string>
    <string name="goal_desc">Fyll hele brettet slik at hver rad, kolonne og 3×3-boks inneholder tallene 1 til 9 én gang hver.</string>
